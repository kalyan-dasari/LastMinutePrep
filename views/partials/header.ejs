<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | LastMinutePrep</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Serif:wght@500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/public/css/style.css" />
  </head>
  <body>
    <div class="bg-grid"></div>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-logo">LMP</span>
        <span>
          <strong>LastMinutePrep</strong>
          <small>Your ReviseHub for Every Exam</small>
        </span>
      </a>
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="/categories">Subjects</a>
        <a href="/leaderboard">Leaderboard</a>
        <a href="/admin-note">Admin Note</a>
        <a href="/last-minute" class="cta-link">Last Minute Mode</a>
        <% if (currentUser) { %>
          <a href="/upload">Upload</a>
          <a href="/dashboard">Dashboard</a>
          <a href="/profile/<%= currentUser.id %>">Profile</a>
          <% if (currentUser.role === 'admin') { %>
            <a href="/admin">Admin</a>
          <% } %>
          <form method="post" action="/logout" class="inline-form">
            <button type="submit">Logout</button>
          </form>
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/register" class="nav-pill">Get Started</a>
        <% } %>
      </nav>
    </header>
    <main class="container">
